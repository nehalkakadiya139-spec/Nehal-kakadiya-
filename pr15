import java.util.*;

class Employee{
    String name,dept;
    void get(String n,String d){name=n;dept=d;}
    void displayDetails(){System.out.println(name+" "+dept);}
}

class Manager extends Employee{
    int team; String project;
    void getM(String n,String d,int t,String p){name=n;dept=d;team=t;project=p;}
    void displayDetails(){System.out.println(name+" "+dept+" "+team+" "+project);}
}

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        Employee e=new Employee();
        Manager m=new Manager();
        e.get(sc.next(),sc.next());
        m.getM(sc.next(),sc.next(),sc.nextInt(),sc.next());
        e.displayDetails();
        m.displayDetails();
    }
}
