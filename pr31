import java.util.*;

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        LinkedList<String> l=new LinkedList<>();
        for(int i=0;i<5;i++)l.add(sc.next());
        System.out.println(l);
        l.removeFirst();
        System.out.println(l);
        l.removeLast();
        System.out.println(l);
    }
}
