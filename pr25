class Table{
    synchronized void print(int n){
        for(int i=1;i<=10;i++)System.out.println(n*i);
    }
}

class T extends Thread{
    Table t; int n;
    T(Table t,int n){this.t=t;this.n=n;}
    public void run(){t.print(n);}
}

public class Main{
    public static void main(String[] args){
        Table t=new Table();
        new T(t,5).start();
        new T(t,7).start();
    }
}
