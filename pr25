class Table {
    synchronized void printTable(int n) {
        for (int i = 1; i <= 10; i++) {
            System.out.println(n * i);
        }
    }
}

class ThreadA extends Thread {
    Table t;
    int num;

    ThreadA(Table t, int n) {
        this.t = t;
        num = n;
    }

    public void run() {
        t.printTable(num);
    }
}

public class Main {
    public static void main(String[] args) {
        Table t = new Table();

        ThreadA t1 = new ThreadA(t, 5);
        ThreadA t2 = new ThreadA(t, 7);

        t1.start();
        t2.start();
    }
}
