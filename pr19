package student;
public class Student{
    int rollNo;
    String name;
    public Student(int r,String n){rollNo=r;name=n;}
    public void displayStudent(){System.out.println(rollNo+" "+name);}
}

package exam;
import student.Student;
import java.util.*;
public class Result extends Student{
    int m1,m2,m3;
    public Result(int r,String n,int a,int b,int c){
        super(r,n);
        m1=a;m2=b;m3=c;
    }
    public void displayResult(){
        displayStudent();
        int total=m1+m2+m3;
        double avg=total/3.0;
        System.out.println(total+" "+avg);
    }
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        Result r=new Result(sc.nextInt(),sc.next(),sc.nextInt(),sc.nextInt(),sc.nextInt());
        r.displayResult();
    }
}
