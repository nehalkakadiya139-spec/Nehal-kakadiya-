import java.util.*;

class BankAccount{
    String id,name; double bal;
    void assign(String i,String n,double b){id=i;name=n;bal=b;}
    void display(){System.out.println(id+" "+name+" "+bal);}
}

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        BankAccount[] a=new BankAccount[5];
        for(int i=0;i<5;i++){
            a[i]=new BankAccount();
            a[i].assign(sc.next(),sc.next(),sc.nextDouble());
        }
        String s=sc.next();
        for(BankAccount x:a) if(x.id.equals(s)) x.display();
    }
}
