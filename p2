import java.util.*;

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt(),res=0,p=1;
        while(n>0){
            int d=(n%10+1)%10;
            res+=d*p;
            p*=10;
            n/=10;
        }
        System.out.println(res);
    }
}
