import java.util.*;

class Loan{
    double calculate(int p,int t,float r){return p*r*t/100;}
    double calculate(double p,int t,double r){return p*r*t/100;}
    double calculate(int p,int t){return p*0.1*t;}
}

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        Loan l=new Loan();
        System.out.println(l.calculate(sc.nextInt(),sc.nextInt(),sc.nextFloat()));
        System.out.println(l.calculate(sc.nextDouble(),sc.nextInt(),sc.nextDouble()));
        System.out.println(l.calculate(sc.nextInt(),sc.nextInt()));
    }
}
